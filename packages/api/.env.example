MONGO_DATABASE=react-project-db
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
CANVAS_MAX_WIDTH=5000
FRONTEND_APP_URL=http://localhost:5173
RESET_TOKEN_TTL_MS=3600000

# ── Seed (utilisateurs par défaut) ───────────────────────────
ADMIN_EMAIL=admin@pixelboard.com
ADMIN_PASSWORD=Admin1234!

# ── SMTP Gmail ───────────────────────────────────────────────
# 1. Activer la validation en 2 étapes sur ton compte Google
# 2. Générer un "Mot de passe d'application" sur https://myaccount.google.com/apppasswords
# 3. Renseigner le mot de passe généré dans SMTP_PASS (pas ton mot de passe Google)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ton.email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=ton.email@gmail.com
