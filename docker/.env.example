# ── MongoDB ─────────────────────────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DATABASE=pixelboard

# ── API (Express) ────────────────────────────────────────
API_PORT=8000
JWT_SECRET=changeme_jwt_secret
JWT_EXPIRES_IN=7d
CANVAS_MAX_WIDTH=5000
CLIENT_URL=http://localhost

# ── Seed (utilisateurs par défaut) ───────────────────────────
ADMIN_EMAIL=admin@pixelboard.local
ADMIN_PASSWORD=Admin1234!

# ── SMTP Gmail ───────────────────────────────────────────────
# Générer un mot de passe d'application sur https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ton.email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=ton.email@gmail.com
FRONTEND_APP_URL=http://localhost
RESET_TOKEN_TTL_MS=3600000

# ── Client (React/Vite) ──────────────────────────────────
# URL de l'API appelée depuis le navigateur
VITE_API_URL=http://localhost:8000/api
